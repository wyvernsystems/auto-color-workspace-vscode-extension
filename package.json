{
  "name": "auto-color",
  "displayName": "Auto Color",
  "description": "Workspace-tinted UI: pastel title, activity, and status bars plus a subtle hue across the workbench—golden-ratio palettes, native-style depth, zero setup.",
  "version": "1.0.0",
  "license": "MIT",
  "publisher": "WyvernSystemsLLC",
  "repository": {
    "type": "git",
    "url": "https://github.com/wyvernsystems/auto-color-vscode-extension.git"
  },
  "bugs": {
    "url": "https://github.com/wyvernsystems/auto-color-vscode-extension/issues"
  },
  "homepage": "https://github.com/wyvernsystems/auto-color-vscode-extension#readme",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "color",
    "workspace",
    "title bar",
    "activity bar",
    "status bar",
    "pastel",
    "multi-root",
    "AutoColorWorkspace"
  ],
  "galleryBanner": {
    "color": "#2a2340",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:auto-color.enableGlobal",
    "onCommand:auto-color.disableGlobal",
    "onCommand:auto-color.enableWorkspace",
    "onCommand:auto-color.disableWorkspace",
    "onCommand:auto-color.setScope",
    "onCommand:auto-color.randomize",
    "onCommand:auto-color.resetColor"
  ],
  "contributes": {
    "commands": [
      {
        "command": "auto-color.enableGlobal",
        "title": "Auto Color: Enable (all windows)"
      },
      {
        "command": "auto-color.disableGlobal",
        "title": "Auto Color: Disable (all windows)"
      },
      {
        "command": "auto-color.enableWorkspace",
        "title": "Auto Color: Enable for this workspace"
      },
      {
        "command": "auto-color.disableWorkspace",
        "title": "Auto Color: Disable for this workspace"
      },
      {
        "command": "auto-color.setScope",
        "title": "Auto Color: Set color scope"
      },
      {
        "command": "auto-color.randomize",
        "title": "Auto Color: Randomize color"
      },
      {
        "command": "auto-color.resetColor",
        "title": "Auto Color: Reset to default color"
      }
    ],
    "configuration": {
      "title": "Auto Color",
      "properties": {
        "auto-color.enabled": {
          "type": "boolean",
          "default": true,
          "scope": "application",
          "description": "Master switch. When false, Auto Color does not apply colors in any window."
        },
        "auto-color.workspaceDisabled": {
          "type": "boolean",
          "default": false,
          "scope": "window",
          "description": "When true, Auto Color is off for this workspace only (extension color keys are cleared)."
        },
        "auto-color.scope": {
          "type": "string",
          "enum": ["all", "headFooter"],
          "default": "all",
          "scope": "window",
          "description": "all = title, activity, status + workbench tint. headFooter = title + status only; activity bar and surfaces use the theme."
        },
        "auto-color.randomSeed": {
          "type": "number",
          "default": 0,
          "scope": "window",
          "description": "Random seed for the workspace color. Set via Randomize; 0 or unset = derive from folder path."
        }
      }
    }
  },
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.2",
    "typescript": "^5.3.3"
  }
}
